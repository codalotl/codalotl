{
  "responses": [
    {
      "name": "basic-tool-initial",
      "consume": true,
      "request": {
        "model": "mock-model-basic-tool-call",
        "input": {
          "match": "partial",
          "text": "Use the available tools if needed to answer what is in @hello.txt."
        },
        "tools": {
          "match": "partial",
          "text": "\"name\":\"read_file\""
        }
      },
      "response": {
        "id": "resp_basic_tool_1",
        "object": "response",
        "usage": {
          "input_tokens": 12,
          "output_tokens": 3
        },
        "output": [
          {
            "id": "fc_basic_tool_1",
            "type": "function_call",
            "call_id": "call_read_hello",
            "name": "read_file",
            "arguments": "{\"path\":\"hello.txt\"}"
          }
        ]
      }
    },
    {
      "name": "basic-tool-followup",
      "consume": true,
      "request": {
        "model": "mock-model-basic-tool-call",
        "previous_response_id": "resp_basic_tool_1",
        "input": {
          "match": "partial",
          "text": "<file name=\"hello.txt\""
        }
      },
      "response": {
        "id": "resp_basic_tool_2",
        "object": "response",
        "usage": {
          "input_tokens": 15,
          "output_tokens": 8
        },
        "output": [
          {
            "id": "msg_basic_tool_2",
            "type": "message",
            "role": "assistant",
            "content": [
              {
                "type": "output_text",
                "text": "hello.txt says: Hello integration world."
              }
            ]
          }
        ]
      }
    }
  ]
}
