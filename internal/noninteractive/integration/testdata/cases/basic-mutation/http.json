        "input": {
          "match": "partial",
          "text": "<apply-patch ok=\"true\">"
        }
      },
      "response": {
        "id": "resp_mutation_2",
        "object": "response",
        "usage": {
          "input_tokens": 12,
          "output_tokens": 7
        },
        "output": [
          {
            "id": "msg_mutation_2",
            "type": "message",
            "role": "assistant",
            "content": [
              {
                "type": "output_text",
                "text": "Updated note.txt to say After mutation."
              }
            ]
          }
        ]
      }
    }
  ]
