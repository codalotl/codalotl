            "role": "assistant",
            "content": [
              {
                "type": "output_text",
                "text": "With multiple `%w` verbs, `fmt.Errorf` returns an error with `Unwrap() []error`, not just a single wrapped error.\n\nBriefly:\n- every `%w` still contributes to the formatted message text\n- the returned unwrap slice contains the wrapped error operands\n- if the same argument is wrapped multiple times, that same argument is only included once\n- with positional formatting, the slice is ordered by argument index"
              }
            ]
          }
